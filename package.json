{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "@allons-y/envoy",
	"version": "1.1.0",
	"description": "Copies values from a root .env into a project .env using .env.example as a template",
	"license": "Apache-2.0",
	"author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.studio)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Allons-y-Studio/envoy.git"
	},
	"bugs": {
		"url": "https://github.com/Allons-y-Studio/envoy/issues"
	},
	"type": "module",
	"main": "index.js",
	"types": "types/index.d.ts",
	"bin": {
		"envoy": "cli.js",
		"envoy-mcp": "mcp.js"
	},
	"files": [
		".github/*.md",
		"README.md",
		"LICENSE",
		"index.js",
		"cli.js",
		"mcp.js",
		"types"
	],
	"scripts": {
		"build:types": "tsc -p tsconfig.types.json",
		"coverage": "c8 yarn test",
		"prepack": "yarn build:types && pinst --disable",
		"precommit": "lint-staged",
		"postinstall": "husky && envoy || true",
		"postpack": "pinst --enable",
		"release": "semantic-release",
		"test": "ava",
		"typecheck": "tsc -p jsconfig.json"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"chalk": "^5.6.2",
		"yargs": "^18.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@types/node": "^25.9.1",
		"ava": "^7.0.0",
		"c8": "^11.0.0",
		"eslint": "^10.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"pinst": "^3.0.0",
		"prettier": "^3.8.3",
		"prettier-package-json": "^2.8.0",
		"semantic-release": "^25.0.3",
		"typescript": "^6.0.3"
	},
	"keywords": [
		"cli",
		"env",
		"environment"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/castastrophe"
		},
		{
			"type": "buy-me-a-coffee",
			"url": "https://www.buymeacoffee.com/castastrophe"
		}
	],
	"packageManager": "yarn@4.15.0"
}
